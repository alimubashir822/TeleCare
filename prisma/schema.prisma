// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        // "ADMIN" | "DOCTOR" | "PATIENT"
  avatar       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctor       Doctor?
  patient      Patient?
  sentMessages Message[]     @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications Notification[]
}

model Doctor {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    String        // "Dermatology" | "Cardiology" | "Pediatrics" | "Psychiatry" | "General Medicine"
  experience   Int           // Years of experience
  languages    String        // Comma-separated: "English, Urdu, Arabic"
  bio          String
  price        Float         // Consultation fee
  rating       Float         @default(5.0)
  availability String        // JSON or custom formatted availability e.g. "Mon-Fri: 9am-5pm"
  appointments Appointment[]
}

model Patient {
  id             String          @id @default(uuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth    DateTime
  gender         String          // "Male" | "Female" | "Other"
  medicalHistory String?         // Text description
  appointments   Appointment[]
  records        MedicalRecord[]
  documents      Document[]
  aiReports      AIReport[]
  vitalLogs      VitalLog[]
}

model Appointment {
  id            String        @id @default(uuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  type          String        // "VIDEO" | "FOLLOWUP" | "EMERGENCY"
  dateTime      DateTime
  status        String        // "PENDING" | "CONFIRMED" | "COMPLETED" | "CANCELLED"
  amount        Float
  paymentStatus String        // "PENDING" | "PAID" | "FAILED"
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  consultation  Consultation?
  payment       Payment?
  videoSession  VideoSession?
}

model Consultation {
  id            String        @id @default(uuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reason        String
  symptoms      String
  notes         String?
  summary       String?       // AI generated visit summary
  status        String        // "IN_PROGRESS" | "COMPLETED"
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  prescriptions Prescription[]
}

model VideoSession {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  roomName      String
  token         String?
  active        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model MedicalRecord {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnosis   String
  treatment   String
  date        DateTime @default(now())
  notes       String?
}

model Prescription {
  id             String       @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  medicine       String
  dosage         String       // e.g. "500mg"
  duration       String       // e.g. "7 Days"
  instructions   String       // e.g. "After meals"
  createdAt      DateTime     @default(now())
}

model Document {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name       String
  fileUrl    String
  fileType   String   // "pdf" | "image" | "docx"
  uploadedAt DateTime @default(now())
}

model Payment {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Float
  provider      String      // "Stripe" | "Mock"
  status        String      // "PENDING" | "PAID" | "FAILED"
  transactionId String?
  createdAt     DateTime    @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  timestamp  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AIReport {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type      String   // "PRE_VISIT_SUMMARY" | "POST_VISIT_CARE"
  content   String   // JSON string containing summary data
  createdAt DateTime @default(now())
}

model VitalLog {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  systolic   Int
  diastolic  Int
  heartRate  Int
  glucose    Int
  recordedAt DateTime @default(now())
}
